        "\n",
        "# Variables independientes\n",
        "X = dataframe[['Loutput', 'Lplabor', 'Lpfuel', 'Lpkap']]\n",
        "\n",
        "formula_translog = 'Ltotcost ~ Loutput + Lpkap + Lplabor + \\\n",
        "                    Lpfuel + np.power(Loutput, 2) +(Loutput:Lpkap) + \\\n",
        "                    (Loutput:Lplabor) + (Loutput:Lpfuel) + np.power(Lpkap, 2) + \\\n",
        "                    np.power(Lplabor, 2) + np.power(Lpfuel, 2) + (Lpkap:Lplabor) + \\\n",
