        "formula_translog2 = 'Ltotcost ~ Loutput + Lpkap + Lplabor + \\\n",
        "                    Lpfuel + np.power(Loutput, 2)'\n",
        "\n",
        "# Ajustar el modelo translog\n",
        "modelo_translog2 = ols(formula_translog2, data=dataframe).fit()\n",
        "\n",
        "# Imprimir los resultados de la estimación\n",
        "print(modelo_translog2.summary())"
