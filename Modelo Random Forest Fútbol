    {
      "cell_type": "markdown",
      "source": [
        "Construcción de la variable \"Diferencia de Goles\""
      ],
      "metadata": {
        "id": "KfPRN-27G9dc"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import openpyxl\n",
        "\n",
        "archivo_excel = r\"Liga MX.xlsx\"\n",
        "wb = openpyxl.load_workbook(archivo_excel)\n",
        "\n",
        "for hoja in wb.worksheets:\n",
        "    hoja.cell(row=1, column=20, value='DG')\n",
        "\n",
        "    for fila in range(2, hoja.max_row + 1):\n",
        "        valor_H = hoja.cell(row=fila, column=8).value\n",
        "        valor_I = hoja.cell(row=fila, column=9).value\n",
        "        if valor_H is None or not isinstance(valor_H, (int, float)):\n",
        "            valor_H = 0\n",
        "        if valor_I is None or not isinstance(valor_I, (int, float)):\n",
        "            valor_I = 0\n",
        "\n",
        "        diferencia = valor_H - valor_I\n",
        "        hoja.cell(row=fila, column=20, value=diferencia)\n",
        "\n",
        "wb.save(archivo_excel)"
      ],
      "metadata": {
        "id": "ZODdyX-mHND2"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Limpieza de datos inncecesarios"
      ],
      "metadata": {
        "id": "PBFGPNzqHmvi"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "wb = openpyxl.load_workbook(archivo_excel)\n",
        "\n",
        "columnas_a_mantener = [1, 10, 20]\n",
        "\n",
        "for hoja in wb.worksheets:\n",
        "    nueva_hoja = wb.create_sheet(title=f\"temp_{hoja.title}\")\n",
        "\n",
        "    for col_index, col_num in enumerate(columnas_a_mantener, start=1):\n",
        "        nueva_hoja.cell(row=1, column=col_index, value=hoja.cell(row=1, column=col_num).value)\n",
        "\n",
        "    for row_index in range(2, hoja.max_row + 1):\n",
        "        if row_index == 22:\n",
        "            continue\n",
        "        for col_index, col_num in enumerate(columnas_a_mantener, start=1):\n",
        "            nueva_hoja.cell(row=row_index if row_index < 22 else row_index - 1, column=col_index, value=hoja.cell(row=row_index, column=col_num).value)\n",
        "\n",
        "    wb.remove(hoja)\n",
        "    nueva_hoja.title = hoja.title\n",
        "\n",
        "wb.save(archivo_excel)\n"
      ],
      "metadata": {
        "id": "6r-9zSk2IQd1"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Obtención del índice de Dificultad del Rival con los promedios de diferencia de goles de los últimos tres partidos"
      ],
      "metadata": {
        "id": "c1Mog4_NIl6o"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "for hoja in wb.worksheets:\n",
        "    hoja.cell(row=1, column=4, value=\"Rendimiento promedio\")\n",
        "\n",
        "    hoja.cell(row=2, column=4, value=0)\n",
        "\n",
        "    hoja.cell(row=3, column=4, value=hoja.cell(row=2, column=3).value)\n",
        "    hoja.cell(row=4, column=4, value=(hoja.cell(row=3, column=3).value + hoja.cell(row=2, column=3).value) / 2)\n",
        "\n",
        "    for fila in range(5, hoja.max_row + 1):\n",
        "        promedio = (hoja.cell(row=fila - 1, column=3).value + hoja.cell(row=fila - 2, column=3).value + hoja.cell(row=fila - 3, column=3).value) / 3\n",
        "        hoja.cell(row=fila, column=4, value=promedio)\n",
        "\n",
        "wb.save(archivo_excel)"
      ],
      "metadata": {
        "id": "6TaMxZQFIxvu"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Proceso de ubicación del valor del índice para cada respectivo rival"
      ],
      "metadata": {
        "id": "A1UOSy37JGwS"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "for hoja_principal in wb.worksheets:\n",
        "    hoja_principal.cell(row=1, column=4, value=\"Rendimiento Promedio Propio\")\n",
        "    hoja_principal.cell(row=1, column=5, value=\"Rendimiento Promedio del Rival\")\n",
        "\n",
        "    for fila in range(2, hoja_principal.max_row + 1):\n",
        "        nombre_hoja = hoja_principal.cell(row=fila, column=2).value\n",
        "        dato_A = hoja_principal.cell(row=fila, column=1).value\n",
        "\n",
        "        if nombre_hoja in wb.sheetnames:\n",
        "            hoja_localizada = wb[nombre_hoja]\n",
        "\n",
        "            for fila_localizada in range(1, hoja_localizada.max_row + 1):\n",
        "                if hoja_localizada.cell(row=fila_localizada, column=1).value == dato_A:\n",
        "                    dato_E = hoja_localizada.cell(row=fila_localizada, column=4).value\n",
        "                    hoja_principal.cell(row=fila, column=5).value = dato_E\n",
        "                    break\n",
        "\n",
        "wb.save(archivo_excel)"
      ],
