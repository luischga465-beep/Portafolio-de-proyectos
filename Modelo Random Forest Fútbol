    {
      "cell_type": "code",
      "source": [
        "nuevos_encabezados = [\"América\", \"Cruz Azul\", \"Guadalajara\", \"Monterrey\", \"Pachuca\", \"Toluca\", \"UANL\", \"UNAM\"]\n",
        "\n",
        "sheets_dict = {}\n",
        "\n",
        "for sheet_name in xlsx.sheet_names:\n",
        "    df = pd.read_excel(xlsx, sheet_name=sheet_name)\n",
        "    columnas_existentes = len(df.columns)\n",
        "    columnas_necesarias = 4 + len(nuevos_encabezados)\n",
        "\n",
        "    if columnas_existentes < columnas_necesarias:\n",
        "        for i in range(columnas_existentes, columnas_necesarias):\n",
        "            df[f'Column{i+1}'] = None\n",
        "\n",
        "    df.columns.values[4:4+len(nuevos_encabezados)] = nuevos_encabezados\n",
        "\n",
        "    for header in nuevos_encabezados:\n",
        "        df[header] = 0\n",
        "\n",
        "    if 'Adversario' in df.columns:\n",
        "        for i, valor in df['Adversario'].iteritems():\n",
        "            if valor in nuevos_encabezados:\n",
        "                col_idx = nuevos_encabezados.index(valor) + 4\n",
        "                df.iat[i, col_idx] = 1\n",
        "\n",
        "    df.iloc[:, 4:4+len(nuevos_encabezados)] = df.iloc[:, 4:4+len(nuevos_encabezados)].fillna(0)\n",
        "\n",
        "    sheets_dict[sheet_name] = df\n",
        "\n",
        "with pd.ExcelWriter(archivo, engine='openpyxl') as writer:\n",
        "    for sheet_name, df in sheets_dict.items():\n",
        "        df.to_excel(writer, sheet_name=sheet_name, index=False)"
